@{
    ViewData["Title"] = "Agenda Diária";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

        <div>
            <h2 class="mb-1">
                Agenda Diária
            </h2>

            <p class="text-muted">
                Sexta-feira, 09 de Maio de 2026
            </p>
        </div>

    </div>

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-body">

            <!-- HORÁRIO -->
            <div class="agenda-item">

                <div class="hora">
                    09:00
                </div>

                <div class="agendamento confirmado">

                    <h5>
                        Maria Silva
                    </h5>

                    <p class="mb-1">
                        Manicure
                    </p>

                    <span class="badge bg-success">
                        Confirmado
                    </span>

                </div>

            </div>

            <!-- HORÁRIO -->
            <div class="agenda-item">

                <div class="hora">
                    10:00
                </div>

                <div class="agendamento pendente">

                    <h5>
                        Ana Souza
                    </h5>

                    <p class="mb-1">
                        Pedicure
                    </p>

                    <span class="badge bg-warning text-dark">
                        Pendente
                    </span>

                </div>

            </div>

            <!-- HORÁRIO LIVRE -->
            <div class="agenda-item">

                <div class="hora">
                    11:00
                </div>

                <div class="agendamento livre">

                    <h5 class="mb-0">
                        Horário Livre
                    </h5>

                </div>

            </div>

            <!-- HORÁRIO -->
            <div class="agenda-item">

                <div class="hora">
                    14:00
                </div>

                <div class="agendamento cancelado">

                    <h5>
                        Juliana Costa
                    </h5>

                    <p class="mb-1">
                        Alongamento
                    </p>

                    <span class="badge bg-danger">
                        Cancelado
                    </span>

                </div>

            </div>

        </div>

    </div>

</div>