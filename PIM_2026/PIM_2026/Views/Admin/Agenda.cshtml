@{
    ViewData["Title"] = "Agenda Diária";
}

<div class="container mt-5">
    <div class="titulo-pagina mb-4">
        <h2>Agenda Diária</h2>
        <p>Sexta-feira, 09 de Maio de 2026</p>
    </div>

    <div class="card-agenda">
        <div class="agenda-item">
            <div class="hora">09:00</div>

            <div class="agendamento confirmado">
                <h5>Maria Silva</h5>
                <p>Manicure</p>
                <span class="badge bg-success">Confirmado</span>
            </div>
        </div>

        <div class="agenda-item">
            <div class="hora">10:00</div>

            <div class="agendamento pendente">
                <h5>Ana Souza</h5>
                <p>Pedicure</p>
                <span class="badge bg-warning text-dark">Pendente</span>
            </div>
        </div>

        <div class="agenda-item">
            <div class="hora">11:00</div>

            <div class="agendamento livre">
                <h5>Horário Livre</h5>
            </div>
        </div>

        <div class="agenda-item">
            <div class="hora">14:00</div>

            <div class="agendamento cancelado">
                <h5>Juliana Costa</h5>
                <p>Alongamento</p>
                <span class="badge bg-danger">Cancelado</span>
            </div>
        </div>

    </div>

</div>