@{
    ViewData["Title"] = "Horário Cadastrado";
}

<div class="container container-confirmacao">
    <div class="card-confirmacao">
        <h2 class="titulo-confirmacao">Horário cadastrado!</h2>

        <p class="texto-confirmacao">O horário foi adicionado ao sistema com sucesso.</p>

        <div class="d-flex flex-column gap-3 botoes-acoes">
            <a asp-action="Horarios" class="btn btn-rosa">Ir para Horários</a>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-rosa">Página Inicial</a>
        </div>
    </div>
</div>