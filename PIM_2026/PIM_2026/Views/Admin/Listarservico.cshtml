@{
    ViewData["Title"] = "Lista de Serviços";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h2 class="titulo-admin">Serviços Cadastrados</h2>
        <a asp-action="Cadastroservico" class="btn btn-rosa">Novo Serviço</a>

    </div>

    <div class="card-tabela">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Preço</th>
                        <th>Duração</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>Alongamento de Unha</td>
                        <td>R$ 120,00</td>
                        <td>60 minutos</td>
                        <td class="text-center botoes-acoes">

                            <button class="btn btn-sm btn-rosa">Editar</button>

                            <button class="btn btn-sm btn-outline-danger">Excluir</button>
                        </td>
                    </tr>

                    <tr>
                        <td>Manicure</td>
                        <td>R$ 45,00</td>
                        <td>40 minutos</td>
                        <td class="text-center botoes-acoes">
                            <button class="btn btn-sm btn-rosa">Editar</button>

                            <button class="btn btn-sm btn-outline-danger">Excluir</button>
                        </td>
                    </tr>

                    <tr>
                        <td>Pedicure</td>
                        <td>R$ 45,00</td>
                        <td>40 minutos</td>
                        <td class="text-center botoes-acoes">
                            <button class="btn btn-sm btn-rosa">Editar</button>
                            <button class="btn btn-sm btn-outline-danger">Excluir</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>