<h2>Cadastrar Serviço</h2>

<!--Verificar depois qual o controle esta integrado com o banco de dados para cadastrar os serviços e o button, para quando clicar em salvar alem de enviar para o banco de dados, ir para a tela SalvarServico.cshtml-->
<form asp-action="" method="post">

    <div>
        <label>Procedimento</label>
        <input type="text" class="form-control" />
    </div>

    <div>
        <label>Preço</label>
        <input type="number" step="0.01" class="form-control" />
    </div>

    <div>
        <label>Duração</label>
        <input type="time" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Salvar</button>

    <a asp-action="Dashboard" class="btn btn-secondary">Cancelar</a>

</form>