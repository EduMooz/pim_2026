@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">📊 Painel Administrativo</h2>

<!-- Card De TOTAL DE CLIENTES -->
<div class="card text-bg-primary mb-3" style="max-width: 18rem;">
    <div class="card-body">
        <h5 class="card-title">Total de clientes</h5>
        <p class="card-text">@ViewBag.TotalClientes</p>
    </div>
</div>

<!-- Tabela com os agendamentos (verificar se irá ser todos os agendamentos ou somente os do dia-->
<h4 class="mb-3">📅 Agendamentos</h4>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Serviço</th>
                        <th>Data</th>
                        <th>Horário</th>
                        <th>Status</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>
                @foreach (var agendamento in ViewBag.ProximosAgendamentos)
                {
                    <tr>
                        <td>@agendamento.Cliente.Nome</td>
                        <td>@agendamento.Serviço.Nome</td>
                        <td>@agendamento.Data.ToShortDateString()</td>
                        <td>@agendamento.Horario.ToString(@"hh\:mm")</td>

                        <!-- STATUS COLORIDO -->
                        <td>
                            @if (agendamento.Status == "Confirmado")
                            {
                                <span class="badge bg-success">Confirmado</span>
                            }
                            else if (agendamento.Status == "Pendente")
                            {
                                <span class="badge bg-warning text-dark">Pendente</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Cancelado</span>
                            }
                        </td>

                        <!-- AÇÕES -->
                        <td class="text-center">
                            <a asp-action="ConfirmarAgendamento"
                                   asp-route-id="@agendamento.IdAgendamento"
                                   class="btn btn-success btn-sm me-1">
                                Confirmar
                            </a>

                            <a asp-action="CancelarAgendamento"
                                   asp-route-id="@agendamento.IdAgendamento"
                                   class="btn btn-outline-danger btn-sm">
                                Cancelar
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>