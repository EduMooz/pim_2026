@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Painel Administrativo</h2>

<!-- CARD TOTAL DE CLIENTES -->
<div class="card text-bg-primary mb-4 shadow-sm" style="max-width: 18rem;">
    <div class="card-body">
        <h5 class="card-title">Total de Clientes</h5>

        <p class="card-text fs-3">25</p>
    </div>
</div>

<h4 class="mb-3">
    Agendamentos
</h4>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Serviço</th>
                        <th>Data</th>
                        <th>Horário</th>
                        <th>Status</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    <!-- LINHA 1 -->
                    <tr>
                        <td>Maria Silva</td>
                        <td>Alongamento</td>
                        <td>10/05/2026</td>
                        <td>14:00</td>

                        <td>
                            <span class="badge bg-success">Confirmado</span>
                        </td>

                        <td class="text-center">
                            <button class="btn btn-success btn-sm me-1">Confirmar</button>

                            <button class="btn btn-outline-danger btn-sm">Cancelar</button>
                        </td>
                    </tr>

                    <!-- LINHA 2 -->
                    <tr>

                        <td>Ana Souza</td>
                        <td>Manicure</td>
                        <td>12/05/2026</td>
                        <td>09:30</td>

                        <td>
                            <span class="badge bg-warning text-dark">Pendente</span>
                        </td>

                        <td class="text-center">
                            <button class="btn btn-success btn-sm me-1">Confirmar</button>

                            <button class="btn btn-outline-danger btn-sm">Cancelar</button>
                        </td>
                    </tr>

                    <!-- LINHA 3 -->
                    <tr>
                        <td>Juliana Costa</td>
                        <td>Pedicure</td>
                        <td>15/05/2026</td>
                        <td>16:00</td>

                        <td>
                            <span class="badge bg-danger">Cancelado</span>
                        </td>

                        <td class="text-center">
                            <button class="btn btn-success btn-sm me-1">Reagendar</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>