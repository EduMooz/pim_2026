@{
    ViewData["Title"] = "Serviço Cadastrado";
}

<div class="container container-confirmacao">
    <div class="card-confirmacao">
        <h2 class="titulo-confirmacao">Serviço cadastrado!</h2>

        <p class="texto-confirmacao">O serviço foi adicionado ao sistema com sucesso.</p>

        <div class="d-flex flex-column gap-3 botoes-acoes">
            <a asp-action="Listarservico" class="btn btn-rosa">Ir para Serviços</a>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-rosa">Página Inicial</a>
        </div>
    </div>
</div>