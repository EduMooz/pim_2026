@{
    ViewData["Title"] = "Controle de Horários";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">

        <h2 class="titulo-admin m-0"><i class="fa-regular fa-clock"></i> Controle de Horários</h2>

        <a asp-action="Cadastrohorario" class="btn btn-rosa"><i class="fa-solid fa-plus"></i> Adicionar Horário</a>

    </div>

    <div class="card-tabela">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Dia</th>
                        <th>Horário</th>
                        <th>Status</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>Segunda-feira</td>
                        <td>08:00 às 18:00</td>
                        <td>
                            <span class="badge bg-success">Livre</span>
                        </td>

                        <td class="text-center botoes-acoes">
                            <button type="button" class="btn btn-warning btn-sm"><i class="fa-solid fa-lock"></i> Bloquear</button>
                            <button type="button" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i> Excluir</button>
                        </td>
                    </tr>

                    <tr>
                        <td>Terça-feira</td>
                        <td>09:00 às 17:00</td>
                        <td>
                            <span class="badge bg-danger">Bloqueado</span>
                        </td>

                        <td class="text-center botoes-acoes">
                            <button type="button" class="btn btn-success btn-sm"><i class="fa-solid fa-lock-open"></i> Liberar</button>
                            <button type="button" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i> Excluir</button>
                        </td>

                    </tr>

                    <tr>
                        <td>Quarta-feira</td>
                        <td>10:00 às 19:00</td>
                        <td>
                            <span class="badge bg-success">Livre</span>
                        </td>

                        <td class="text-center botoes-acoes">
                            <button type="button" class="btn btn-warning btn-sm"><i class="fa-solid fa-lock"></i> Bloquear</button>
                            <button type="button" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i> Excluir</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>