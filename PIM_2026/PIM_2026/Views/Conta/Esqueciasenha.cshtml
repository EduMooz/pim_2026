@{
    ViewData["Title"] = "Redefinir senha";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg p-4 rounded-4">

                <h3 class="text-center mb-3">Redefinir senha</h3>
                <p class="text-muted text-center mb-4">Digite seu email e a nova senha</p>

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger text-center">
                        @ViewBag.Erro
                    </div>
                }

                @if (ViewBag.Sucesso != null)
                {
                    <div class="alert alert-success text-center">
                        @ViewBag.Sucesso
                    </div>
                }

                <form action="/Conta/Login" method="post">

                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert alert-danger text-center">
                            @ViewBag.Erro
                        </div>
                    }

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" name="email" class="form-control" required>
                    </div>

                    <div class="mb-3">
                        <label>Nova senha</label>
                        <input type="password" name="senha" class="form-control" required>
                    </div>

                    <!--Verificar-->
                    <div class="mb-3">
                        <label>Digite novamente a nova senha</label>
                        <input type="password" name="senha" class="form-control" required>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Entrar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>






