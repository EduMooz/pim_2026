@model PIM_2026.Models.Cliente

@{
    ViewData["Title"] = "Login";
}

<div class="container container-login-mobile container-formulario d-flex justify-content-center">
    <div class="card-login">
        <h3 class="text-center mb-4">Área do Cliente</h3>

        <ul class="nav nav-tabs mb-3" id="abasLogin" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="login-tab" data-bs-toggle="tab" data-bs-target="#login" type="button"><i class="fa-solid fa-circle-user"></i> Login</button>
            </li>

            <li class="nav-item" role="presentation">
                <button class="nav-link" id="cadastro-tab" data-bs-toggle="tab" data-bs-target="#cadastro" type="button"><i class="fa-solid fa-user-plus"></i> Cadastro</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="login">
                <form method="post" asp-controller="Conta" asp-action="Login">
                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert alert-danger text-center">
                            @ViewBag.Erro
                        </div>
                    }

                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" name="Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label>Senha</label>
                        <input type="password" name="Senha" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-rosa w-100">Entrar</button>

                    <div class="text-center mt-3">
                        <a asp-controller="Conta" asp-action="Esqueciasenha"><i class="fa-solid fa-key"></i> Esqueci minha senha</a>
                    </div>
                </form>
            </div>

            <div class="tab-pane fade" id="cadastro">
                <form method="post" asp-controller="Conta" asp-action="Cadastro">
                    <div class="mb-3">
                        <label>Nome</label>
                        <input asp-for="Nome" class="form-control" placeholder="Digite seu nome" required />
                    </div>

                    <div class="mb-3">
                        <label>Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Digite seu email" required />
                    </div>

                    <div class="mb-3">
                        <label>Senha</label>
                        <input asp-for="Senha" type="password" class="form-control" placeholder="Digite sua senha" required />
                    </div>

                    <div class="mb-3">
                        <label>Telefone</label>
                        <input asp-for="Telefone" type="tel" class="form-control" placeholder="Digite seu telefone" required />
                    </div>

                    <button type="submit" class="btn btn-rosa w-100">Cadastrar</button>
                </form>
            </div>
        </div>
    </div>
</div>