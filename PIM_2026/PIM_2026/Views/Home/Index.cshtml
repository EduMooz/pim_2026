@{
    ViewData["Title"] = "Página Inicial";
}

<main>
    <section class="hero">
        <h1>Erika Santana</h1>
        <p class="subtitulo">Especialista em manicure e nail design</p>
        <p class="descricao">Atendimento personalizado, esmaltação impecável e unhas que valorizam sua beleza.</p>
            
        <a asp-controller="Conta" asp-action="Cadastro" class="btn btn-rosa">Agende seu horário</a>
    </section>

        
    <section class="servicos">
        <h2>Serviços oferecidos</h2>
        <p>Confira alguns dos nossos serviços</p>

        <div class="row">

            <div class="col-md-6">
                <div class="card-servico">
                    <img src="~/img/foto_mao2.jpeg" alt="Cutilagem das mãos" />
                    <div class="texto-card">
                        <h3>Cutilagem e Esmaltação das Mãos</h3>
                        <p>Remoção de cutículas, lixamento e esmaltação com acabamento cuidados para unhas bonitas e bem cuidadas</p>
                        <span>R$45,00 • 45 min</span>
                    </div>
                    
                </div>
            </div>

            <div class="col-md-6">
                <div class="card-servico">
                    <img src="~/img/foto_pe.jpeg" alt="Cutilagem dos pés" />
                    <div class="texto-card">
                        <h3>Cutilagem e Esmaltação dos Pés</h3>
                        <p>Cuidados com cutículas, lixamento e esmaltação para pés bonitos e bem cuidados.</p>
                        <span>R$50,00 • 60 min</span>
                    </div>
                    
                </div>
            </div>
        </div>
    </section>

    <section class="localizacao">
        <h2>Localização</h2>

        <div class="container-localizacao">
        
            <!-- LADO ESQUERDO -->
            <div class="coluna-esquerda">
                <h3>Endereço</h3>
                <p>
                    Rua das Flores, 123 - Jardim Primavera<br />
                    São Paulo - SP<br />
                    CEP: 01234-567
                </p>
            
                <h3>Horário de Atendimento</h3>
                <p>
                    Segunda a Sexta: 9h às 19h <br />
                    Sábado: 9h às 17h <br />
                    Domingo: Fechado
                </p>
            </div>

            <!-- LADO DIREITO -->
            <div class="coluna-direita">
                <h3>Contato</h3>
                <div class="redes">
                    <a href="https://wa.me/5516999999999" target="_blank" class="icon-whatsapp">
                        <i class="fa-brands fa-whatsapp"></i>
                    </a>

                    <a href="https://instagram.com/erikasant" target="_blank" class="icon-instagram">
                        <i class="fa-brands fa-instagram"></i>
                    </a>
                </div>
            </div>

        </div>
    </section>
</main>