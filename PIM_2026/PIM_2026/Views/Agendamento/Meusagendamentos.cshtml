@{
    ViewData["Title"] = "Meus Agendamentos";
}

<div class="container-agendamentos">

    <div class="text-center mb-5">
        <h2 class="titulo-pagina">Meus Agendamentos</h2>

        <p class="texto-pagina">Acompanhe seus horários </p>
    </div>

    <div class="row">
        <!-- AGENDAMENTO -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card-meu-agendamento">
                <div class="status-topo status-confirmado"></div>

                <div class="conteudo-agendamento">
                    <h4>Alongamento de Unha</h4>

                    <p><i class="fa-solid fa-calendar"></i> <strong>Data:</strong>10/05/2026</p>

                    <p><i class="fa-regular fa-clock"></i> <strong>Horário:</strong>14:00</p>

                    <span class="badge-status confirmado"><i class="fa-solid fa-check"></i> Confirmado</span>

                    <div class="d-flex gap-2 mt-4 botoes-acoes">
                        <button class="btn btn-rosa w-100" disabled>Confirmado</button>

                        <button class="btn btn-outline-rosa w-100">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- AGENDAMENTO -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card-meu-agendamento">
                <div class="status-topo status-pendente"></div>

                <div class="conteudo-agendamento">
                    <h4>Manicure</h4>

                    <p><i class="fa-solid fa-calendar"></i> <strong>Data:</strong>15/05/2026</p>

                    <p><i class="fa-regular fa-clock"></i> <strong>Horário:</strong>09:30</p>

                    <span class="badge-status pendente"><i class="fa-solid fa-clock"></i> Pendente</span>

                    <div class="d-flex gap-2 mt-4 botoes-acoes">
                        <button class="btn btn-rosa w-100">Confirmar</button>

                        <button class="btn btn-outline-rosa w-100">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- AGENDAMENTO -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card-meu-agendamento">
                <div class="status-topo status-cancelado"></div>

                <div class="conteudo-agendamento">
                    <h4>Hidratação dos pés</h4>

                    <p><i class="fa-solid fa-calendar"></i> <strong>Data:</strong>25/05/2026</p>

                    <p><i class="fa-regular fa-clock"></i> <strong>Horário:</strong>14:00</p>

                    <span class="badge-status cancelado"><i class="fa-regular fa-circle-xmark"></i> Cancelado</span>

                    <div class="d-flex gap-2 mt-4 botoes-acoes">
                        <button class="btn btn-rosa w-100" disabled>Confirmar</button>

                        <button class="btn btn-outline-rosa w-100" disabled>Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>