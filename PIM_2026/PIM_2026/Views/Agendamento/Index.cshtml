@{
    ViewData["Title"] = "Agendamento";
}

<div class="container py-5">

    <h2 class="text-center mb-4">Agende seu Horário</h2>

    <div class="card shadow-lg p-4 rounded-4">
        <form method="post" asp-controller="Agendamento" asp-action="Salvaragendamento" id="formAgendamento">

            <!-- ABAS -->
            <ul class="nav nav-pills nav-justified mb-4" id="abasAgendamento">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#procedimento" type="button">Procedimento</button>
                </li>

                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#dataHorario" type="button">Data e horário</button>
                </li>

                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="pill" data-bs-target="#resumo" type="button">Resumo</button>
                </li>
            </ul>

            <!-- CONTEÚDO DAS ABAS -->
            <div class="tab-content">

                <!-- PROCEDIMENTO -->
                <div class="tab-pane fade show active" id="procedimento">
                    <h4 class="mb-3">Escolha o serviço</h4>

                    <select class="form-select mb-4" name="Servico" id="servico" required>
                        <option value="">Selecione um serviço</option>

                        <optgroup label="Serviços para Mão">
                            <option>Manicure Tradicional</option>
                            <option>Esmaltação em Gel</option>
                            <option>Alongamento de Unhas</option>
                            <option>Cuticulagem</option>
                            <option>Remoção do alongamento</option>
                        </optgroup>

                        <optgroup label="Serviços para Pé">
                            <option>Pedicure Tradicional</option>
                            <option>Spa dos Pés</option>
                            <option>Hidratação dos Pés</option>
                            <option>Cuticulagem dos Pés</option>
                        </optgroup>
                    </select>

                    <div class="text-end">
                        <button type="button" class="btn btn-rosa" onclick="validarProcedimento()">Próximo</button>
                    </div>
                </div>

                <!-- DATA E HORÁRIO -->
                <div class="tab-pane fade" id="dataHorario">
                    <h4 class="mb-3">Escolha a data</h4>
                    <!--Adicionar um calendario-->
                    <input type="date" class="form-control mb-4" name="Data" id="data" required>

                    <h4 class="mb-3">Escolha o horário</h4>
                    <select class="form-select mb-4" name="Horario" id="horario" required>
                        <option value="">Selecione um horário</option>
                        <option>09:00</option>
                        <option>10:00</option>
                        <option>11:00</option>
                        <option>14:00</option>
                        <option>15:00</option>
                        <option>16:00</option>
                    </select>

                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-outline-secondary" onclick="irParaAba('procedimento')">Voltar</button>

                        <button type="button" class="btn btn-rosa" onclick="validarDataHorario()">Próximo</button>
                    </div>
                </div>


                <!-- RESUMO -->
                <div class="tab-pane fade" id="resumo">
                    <h4 class="mb-4">Resumo do Agendamento</h4>

                    <div class="bg-light rounded p-4 mb-4">
                        <p>
                            <strong>Serviço:</strong>
                            <span id="resumoServico"></span>
                        </p>

                        <p>
                            <strong>Data:</strong>
                            <span id="resumoData"></span>
                        </p>

                        <p>
                            <strong>Horário:</strong>
                            <span id="resumoHorario"></span>
                        </p>
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="button"class="btn btn-outline-secondary" onclick="irParaAba('dataHorario')">Voltar</button>
                        <div class="d-flex gap-2">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-danger">Cancelar</a>
                            <button type="submit" class="btn btn-success">Confirmar Agendamento</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>


<script>

    function irParaAba(idAba) {

        const trigger = document.querySelector(
            `[data-bs-target="#${idAba}"]`
        );

        bootstrap.Tab.getOrCreateInstance(trigger).show();
    }

    // VALIDAR PROCEDIMENTO
    function validarProcedimento() {

        const servico =
            document.getElementById("servico").value;

        if (servico === "") {

            alert("Selecione um serviço para continuar.");

            return;
        }

        irParaAba('dataHorario');
    }

    // VALIDAR DATA E HORÁRIO
    function validarDataHorario() {

        const data =
            document.getElementById("data").value;

        const horario =
            document.getElementById("horario").value;

        if (data === "" || horario === "") {

            alert("Selecione a data e o horário.");

            return;
        }

        mostrarResumo();
    }

    // MOSTRAR RESUMO
    function mostrarResumo() {

        document.getElementById("resumoServico").innerText =
            document.getElementById("servico").value;

        document.getElementById("resumoData").innerText =
            document.getElementById("data").value;

        document.getElementById("resumoHorario").innerText =
            document.getElementById("horario").value;

        irParaAba('resumo');
    }

</script>