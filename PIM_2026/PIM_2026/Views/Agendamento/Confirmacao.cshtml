@{
    ViewData["Title"] = "Confirmação";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow p-5 text-center" style="max-width: 500px;">

        <h2 class="text-success mb-3">Agendamento Confirmado!</h2>

        <p class="mb-4">Seu agendamento foi realizado com sucesso.</p>

        <a asp-action="Meusagendamentos" class="btn btn-primary mt-3">Ir para meus agendamentos</a>
